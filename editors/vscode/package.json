{
  "name": "plc-vscode",
  "displayName": "PLC VS Code",
  "description": "Structured Text / IEC 61131-3 support backed by the PLC VS Code Rust language server.",
  "version": "0.2.2",
  "publisher": "raccoonsoftware",
  "private": true,
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:structured-text",
    "onCommand:plc-vscode.showStatus",
    "onCommand:plc-vscode.runCurrentFile",
    "onCommand:plc-vscode.debugCurrentFile",
    "onCommand:plc-vscode.buildCpdev",
    "onDebugResolve:plc-st",
    "onDebugDynamicConfigurations:plc-st"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "structured-text",
        "aliases": [
          "Structured Text",
          "IEC 61131-3 ST",
          "ST"
        ],
        "extensions": [
          ".st",
          ".iecst",
          ".plcst"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "structured-text",
        "scopeName": "source.st",
        "path": "./syntaxes/structured-text.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "structured-text"
      }
    ],
    "debuggers": [
      {
        "type": "plc-st",
        "label": "PLC Structured Text",
        "languages": [
          "structured-text"
        ],
        "configurationAttributes": {
          "launch": {
            "properties": {
              "program": {
                "type": "string",
                "description": "Absolute path to the Structured Text file to debug.",
                "default": "${file}"
              },
              "scans": {
                "type": "number",
                "description": "Number of scan cycles to execute.",
                "default": 25
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "plc-st",
            "request": "launch",
            "name": "PLC: Debug Structured Text",
            "program": "${file}",
            "scans": 25
          }
        ],
        "configurationSnippets": [
          {
            "label": "PLC: Debug Structured Text",
            "description": "Debug the current Structured Text file",
            "body": {
              "type": "plc-st",
              "request": "launch",
              "name": "PLC: Debug Structured Text",
              "program": "^\"\\${file}\"",
              "scans": 25
            }
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "plc-vscode.showStatus",
        "title": "PLC VS Code: Show Language Server Status"
      },
      {
        "command": "plc-vscode.runCurrentFile",
        "title": "PLC VS Code: Run Current Structured Text File"
      },
      {
        "command": "plc-vscode.debugCurrentFile",
        "title": "PLC VS Code: Debug Current Structured Text File"
      },
      {
        "command": "plc-vscode.buildCpdev",
        "title": "PLC VS Code: Compile to CPDev .xcp"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "plc-vscode.runCurrentFile",
          "group": "navigation@0",
          "when": "resourceLangId == structured-text"
        },
        {
          "command": "plc-vscode.debugCurrentFile",
          "group": "navigation@1",
          "when": "resourceLangId == structured-text"
        },
        {
          "command": "plc-vscode.buildCpdev",
          "group": "navigation@2",
          "when": "resourceLangId == structured-text"
        }
      ],
      "editor/context": [
        {
          "command": "plc-vscode.runCurrentFile",
          "group": "navigation@10",
          "when": "editorLangId == structured-text"
        },
        {
          "command": "plc-vscode.debugCurrentFile",
          "group": "navigation@11",
          "when": "editorLangId == structured-text"
        },
        {
          "command": "plc-vscode.buildCpdev",
          "group": "navigation@12",
          "when": "editorLangId == structured-text"
        }
      ],
      "explorer/context": [
        {
          "command": "plc-vscode.runCurrentFile",
          "group": "navigation@10",
          "when": "resourceLangId == structured-text"
        },
        {
          "command": "plc-vscode.debugCurrentFile",
          "group": "navigation@11",
          "when": "resourceLangId == structured-text"
        },
        {
          "command": "plc-vscode.buildCpdev",
          "group": "navigation@12",
          "when": "resourceLangId == structured-text"
        }
      ]
    },
    "configuration": {
      "title": "PLC VS Code",
      "properties": {
        "plcVscode.serverCommand": {
          "type": "string",
          "default": "cargo",
          "description": "Command used to launch the PLC VS Code language server in development."
        },
        "plcVscode.serverArgs": {
          "type": "array",
          "default": [
            "run",
            "--package",
            "plc_lsp_server",
            "--bin",
            "plc-lsp-server",
            "--"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments used to launch the PLC VS Code language server in development."
        },
        "plcVscode.repositoryRoot": {
          "type": "string",
          "default": "",
          "description": "Repository root used to run development Rust commands. Leave empty for extension development mode."
        },
        "plcVscode.cliCommand": {
          "type": "string",
          "default": "cargo",
          "description": "Command used by the extension to execute Structured Text files."
        },
        "plcVscode.cliArgs": {
          "type": "array",
          "default": [
            "run",
            "--quiet",
            "--package",
            "plc_cli",
            "--",
            "run"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments prepended before the current file path when running Structured Text."
        },
        "plcVscode.autoRunOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run a Structured Text file when it is opened. Intended for demos and smoke tests."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node test/package-contract.test.js && node test/verify-vsix.test.js",
    "verify-vsix": "node scripts/verify-vsix.js",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.92.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jash90/plc-vscode.git",
    "directory": "editors/vscode"
  },
  "license": "SEE LICENSE IN LICENSE"
}
