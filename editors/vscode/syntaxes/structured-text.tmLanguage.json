{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Structured Text",
  "scopeName": "source.st",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.st",
          "match": "//.*$"
        },
        {
          "name": "comment.block.st",
          "begin": "\\(\\*",
          "end": "\\*\\)"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.single.st",
          "begin": "'",
          "end": "'",
          "patterns": [{ "name": "constant.character.escape.st", "match": "\\$." }]
        },
        {
          "name": "string.quoted.double.st",
          "begin": "\"",
          "end": "\"",
          "patterns": [{ "name": "constant.character.escape.st", "match": "\\$." }]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.time.st",
          "match": "(?i)\\b(T|TIME|LT|LTIME)#[0-9smhd._]+\\b"
        },
        {
          "name": "constant.numeric.based.st",
          "match": "(?i)\\b(2|8|16)#[0-9a-f_]+\\b"
        },
        {
          "name": "constant.numeric.st",
          "match": "\\b[0-9][0-9_]*(\\.[0-9_]+)?([eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.pou.st",
          "match": "(?i)\\b(PROGRAM|END_PROGRAM|FUNCTION_BLOCK|END_FUNCTION_BLOCK|FUNCTION|END_FUNCTION|ACTION|END_ACTION|METHOD|END_METHOD)\\b"
        },
        {
          "name": "keyword.control.var.st",
          "match": "(?i)\\b(VAR_INPUT|VAR_OUTPUT|VAR_IN_OUT|VAR_GLOBAL|VAR_TEMP|VAR_EXTERNAL|VAR|END_VAR|CONSTANT|RETAIN|NON_RETAIN)\\b"
        },
        {
          "name": "keyword.control.flow.st",
          "match": "(?i)\\b(IF|THEN|ELSIF|ELSE|END_IF|CASE|OF|END_CASE|FOR|TO|BY|DO|END_FOR|WHILE|END_WHILE|REPEAT|UNTIL|END_REPEAT|RETURN|EXIT|CONTINUE)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.elementary.st",
          "match": "(?i)\\b(BOOL|BYTE|WORD|DWORD|LWORD|SINT|INT|DINT|LINT|USINT|UINT|UDINT|ULINT|REAL|LREAL|TIME|LTIME|DATE|TIME_OF_DAY|TOD|DATE_AND_TIME|DT|STRING|WSTRING|CHAR|WCHAR)\\b"
        },
        {
          "name": "storage.type.derived.st",
          "match": "(?i)\\b(ARRAY|STRUCT|END_STRUCT|TYPE|END_TYPE)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.st",
          "match": "(?i)\\b(TRUE|FALSE)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.st",
          "match": "(?i)\\b(AND|OR|XOR|NOT|MOD)\\b"
        },
        {
          "name": "keyword.operator.assignment.st",
          "match": ":=|=>"
        },
        {
          "name": "keyword.operator.comparison.st",
          "match": "<=|>=|<>|=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.st",
          "match": "\\+|-|\\*\\*|\\*|/"
        }
      ]
    }
  }
}
