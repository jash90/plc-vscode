TEST_PROGRAM oscat_advanced_math_helpers_behave
VAR
    Fraction : FRACTION;
END_VAR

ASSERT_TRUE(IN := OSCAT_BASIC_Constants());
ASSERT_NEAR(EXPECTED := REAL#0.567143, ACTUAL := LAMBERT_W(X := REAL#1.0), DELTA := REAL#0.002);
ASSERT_NEAR(EXPECTED := REAL#0.313035, ACTUAL := LANGEVIN(X := REAL#1.0), DELTA := REAL#0.002);
Fraction := REAL_TO_FRAC(X := REAL#0.75, N := INT#10);
ASSERT_EQUAL(EXPECTED := INT#3, ACTUAL := Fraction.NUMERATOR);
ASSERT_EQUAL(EXPECTED := INT#4, ACTUAL := Fraction.DENOMINATOR);
ASSERT_NEAR(EXPECTED := REAL#3.1, ACTUAL := RND(X := REAL#3.19, N := INT#2), DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#3.15, ACTUAL := ROUND(IN := REAL#3.146, N := INT#2), DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#0.5, ACTUAL := SIGMOID(X := REAL#0.0), DELTA := REAL#0.001);
ASSERT_TRUE(IN := SIGN_I(IN := DINT#-1));
ASSERT_TRUE(IN := SIGN_R(IN := REAL#-0.1));
ASSERT_NEAR(EXPECTED := REAL#1.0, ACTUAL := SINC(X := REAL#0.0), DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#3.0, ACTUAL := SQRTN(X := REAL#27.0, N := INT#3), DELTA := REAL#0.002);
ASSERT_NEAR(EXPECTED := REAL#1.0, ACTUAL := TANC(X := REAL#0.0), DELTA := REAL#0.001);
ASSERT_TRUE(IN := WINDOW(LOW := REAL#0.0, IN := REAL#0.5, HIGH := REAL#1.0));
ASSERT_FALSE(IN := WINDOW(LOW := REAL#0.0, IN := REAL#1.0, HIGH := REAL#1.0));
ASSERT_TRUE(IN := WINDOW2(LOW := REAL#0.0, IN := REAL#1.0, HIGH := REAL#1.0));
END_TEST_PROGRAM

TEST_PROGRAM oscat_random_math_helpers_behave
VAR
    RandomReal : REAL;
    RandomInt : INT;
    RandomDw : DWORD;
END_VAR

ASSERT_TRUE(IN := OSCAT_BASIC_Constants());
RandomReal := RDM(LAST := REAL#0.25);
ASSERT_TRUE(IN := RandomReal >= REAL#0.0);
ASSERT_TRUE(IN := RandomReal <= REAL#1.0);
RandomInt := RDM2(LAST := INT#17, LOW := INT#3, HIGH := INT#6);
ASSERT_TRUE(IN := RandomInt >= INT#3);
ASSERT_TRUE(IN := RandomInt <= INT#6);
RandomDw := RDMDW(LAST := DWORD#12345);
ASSERT_TRUE(IN := BIT_COUNT(IN := RandomDw) >= INT#0);
END_TEST_PROGRAM
