TEST_PROGRAM oscat_complex_number_construction_and_algebra_behave
VAR
    X : COMPLEX;
    Y : COMPLEX;
    Z : COMPLEX;
END_VAR

ASSERT_TRUE(IN := OSCAT_BASIC_Constants());

Z := CSET(RE := REAL#3.0, IM := REAL#4.0);
ASSERT_NEAR(EXPECTED := REAL#3.0, ACTUAL := Z.RE, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#4.0, ACTUAL := Z.IM, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#5.0, ACTUAL := CABS(X := Z), DELTA := REAL#0.001);

X := CSET(RE := REAL#1.0, IM := REAL#2.0);
Y := CSET(RE := REAL#3.0, IM := REAL#4.0);

Z := CADD(X := X, Y := Y);
ASSERT_NEAR(EXPECTED := REAL#4.0, ACTUAL := Z.RE, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#6.0, ACTUAL := Z.IM, DELTA := REAL#0.001);

Z := CSUB(X := Y, Y := X);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Z.RE, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Z.IM, DELTA := REAL#0.001);

Z := CMUL(X := X, Y := Y);
ASSERT_NEAR(EXPECTED := REAL#-5.0, ACTUAL := Z.RE, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#10.0, ACTUAL := Z.IM, DELTA := REAL#0.001);

Z := CDIV(X := X, Y := Y);
ASSERT_NEAR(EXPECTED := REAL#0.44, ACTUAL := Z.RE, DELTA := REAL#0.002);
ASSERT_NEAR(EXPECTED := REAL#0.08, ACTUAL := Z.IM, DELTA := REAL#0.002);

Z := CCON(X := Y);
ASSERT_NEAR(EXPECTED := REAL#3.0, ACTUAL := Z.RE, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#-4.0, ACTUAL := Z.IM, DELTA := REAL#0.001);

Z := CINV(X := CSET(RE := REAL#1.0, IM := REAL#1.0));
ASSERT_NEAR(EXPECTED := REAL#0.5, ACTUAL := Z.RE, DELTA := REAL#0.002);
ASSERT_NEAR(EXPECTED := REAL#-0.5, ACTUAL := Z.IM, DELTA := REAL#0.002);

ASSERT_NEAR(EXPECTED := MATH.PI05, ACTUAL := CARG(X := CSET(RE := REAL#0.0, IM := REAL#1.0)), DELTA := REAL#0.002);

Z := CPOL(L := REAL#2.0, A := MATH.PI05);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Z.RE, DELTA := REAL#0.002);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Z.IM, DELTA := REAL#0.002);
END_TEST_PROGRAM

TEST_PROGRAM oscat_complex_exponential_logarithmic_and_power_helpers_behave
VAR
    Z : COMPLEX;
END_VAR

ASSERT_TRUE(IN := OSCAT_BASIC_Constants());

Z := CEXP(X := CSET(RE := REAL#0.0, IM := REAL#0.0));
ASSERT_NEAR(EXPECTED := REAL#1.0, ACTUAL := Z.RE, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Z.IM, DELTA := REAL#0.001);

Z := CLOG(X := CSET(RE := REAL#1.0, IM := REAL#0.0));
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Z.RE, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Z.IM, DELTA := REAL#0.001);

Z := CSQRT(X := CSET(RE := REAL#3.0, IM := REAL#4.0));
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Z.RE, DELTA := REAL#0.002);
ASSERT_NEAR(EXPECTED := REAL#1.0, ACTUAL := Z.IM, DELTA := REAL#0.002);

Z := CPOW(X := CSET(RE := REAL#2.0, IM := REAL#0.0), Y := CSET(RE := REAL#3.0, IM := REAL#0.0));
ASSERT_NEAR(EXPECTED := REAL#8.0, ACTUAL := Z.RE, DELTA := REAL#0.01);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Z.IM, DELTA := REAL#0.01);
END_TEST_PROGRAM

