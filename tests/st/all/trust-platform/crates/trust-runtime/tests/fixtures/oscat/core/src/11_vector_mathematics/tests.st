TEST_PROGRAM oscat_vector_algebra_helpers_behave
VAR
    A : VECTOR_3;
    B : VECTOR_3;
    ZeroVector : VECTOR_3;
    Result : VECTOR_3;
END_VAR

A.X := REAL#1.0;
A.Y := REAL#2.0;
A.Z := REAL#2.0;
B.X := REAL#2.0;
B.Y := REAL#0.0;
B.Z := REAL#1.0;

ASSERT_NEAR(EXPECTED := REAL#3.0, ACTUAL := V3_ABS(A := A), DELTA := REAL#0.0001);

Result := V3_ADD(A := A, B := B);
ASSERT_NEAR(EXPECTED := REAL#3.0, ACTUAL := Result.X, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Result.Y, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#3.0, ACTUAL := Result.Z, DELTA := REAL#0.0001);

Result := V3_SUB(A := A, B := B);
ASSERT_NEAR(EXPECTED := REAL#-1.0, ACTUAL := Result.X, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Result.Y, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#1.0, ACTUAL := Result.Z, DELTA := REAL#0.0001);

ASSERT_NEAR(EXPECTED := REAL#4.0, ACTUAL := V3_DPRO(A := A, B := B), DELTA := REAL#0.0001);

Result := V3_XPRO(A := A, B := B);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Result.X, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#3.0, ACTUAL := Result.Y, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#-4.0, ACTUAL := Result.Z, DELTA := REAL#0.0001);

Result := V3_SMUL(A := A, M := REAL#0.5);
ASSERT_NEAR(EXPECTED := REAL#0.5, ACTUAL := Result.X, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#1.0, ACTUAL := Result.Y, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#1.0, ACTUAL := Result.Z, DELTA := REAL#0.0001);

Result := V3_REV(A := A);
ASSERT_NEAR(EXPECTED := REAL#-1.0, ACTUAL := Result.X, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#-2.0, ACTUAL := Result.Y, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#-2.0, ACTUAL := Result.Z, DELTA := REAL#0.0001);

Result := V3_NORM(A := A);
ASSERT_NEAR(EXPECTED := REAL#0.333333, ACTUAL := Result.X, DELTA := REAL#0.0005);
ASSERT_NEAR(EXPECTED := REAL#0.666667, ACTUAL := Result.Y, DELTA := REAL#0.0005);
ASSERT_NEAR(EXPECTED := REAL#0.666667, ACTUAL := Result.Z, DELTA := REAL#0.0005);

ASSERT_TRUE(IN := V3_NUL(A := ZeroVector));
ASSERT_FALSE(IN := V3_NUL(A := A));
ASSERT_TRUE(IN := V3_PAR(A := A, B := V3_SMUL(A := A, M := REAL#2.0)));
ASSERT_FALSE(IN := V3_PAR(A := A, B := B));
END_TEST_PROGRAM

TEST_PROGRAM oscat_vector_angle_helpers_behave
VAR
    XAxis : VECTOR_3;
    YAxis : VECTOR_3;
    ZAxis : VECTOR_3;
END_VAR

ASSERT_TRUE(IN := OSCAT_BASIC_Constants());

XAxis.X := REAL#1.0;
YAxis.Y := REAL#1.0;
ZAxis.Z := REAL#1.0;

ASSERT_NEAR(EXPECTED := MATH.PI05, ACTUAL := V3_ANG(A := XAxis, B := YAxis), DELTA := REAL#0.0005);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := V3_XANG(A := XAxis), DELTA := REAL#0.0005);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := V3_YANG(A := YAxis), DELTA := REAL#0.0005);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := V3_ZANG(A := ZAxis), DELTA := REAL#0.0005);
END_TEST_PROGRAM
