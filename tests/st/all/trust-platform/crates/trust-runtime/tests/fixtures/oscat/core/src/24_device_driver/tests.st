TEST_PROGRAM oscat_device_driver_tuning_helpers_behave
VAR
    Ramp : SRAMP;
    FineTune : TUNE;
    FastTune : TUNE2;
    Encoder : INC_DEC;
END_VAR

Ramp(X := REAL#10.0, A_UP := REAL#1.0, A_DN := REAL#-1.0, VU_MAX := REAL#5.0, VD_MAX := REAL#-5.0, LIMIT_HIGH := REAL#100.0, LIMIT_LOW := REAL#0.0, RST := TRUE);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Ramp.Y, DELTA := REAL#0.001);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Ramp.V, DELTA := REAL#0.001);

FineTune(SET_REQ := TRUE, SU := FALSE, SD := FALSE, RST := FALSE, LIMIT_L := REAL#0.0, LIMIT_H := REAL#100.0, RST_val := REAL#5.0, SET_val := REAL#25.0);
ASSERT_NEAR(EXPECTED := REAL#25.0, ACTUAL := FineTune.Y, DELTA := REAL#0.001);
FineTune(SET_REQ := FALSE, SU := FALSE, SD := FALSE, RST := TRUE, LIMIT_L := REAL#0.0, LIMIT_H := REAL#100.0, RST_val := REAL#5.0, SET_val := REAL#25.0);
ASSERT_NEAR(EXPECTED := REAL#5.0, ACTUAL := FineTune.Y, DELTA := REAL#0.001);

FastTune(SET_REQ := TRUE, SU := FALSE, SD := FALSE, FU := FALSE, FD := FALSE, RST := FALSE, LIMIT_L := REAL#0.0, LIMIT_H := REAL#100.0, RST_val := REAL#7.0, SET_val := REAL#30.0);
ASSERT_NEAR(EXPECTED := REAL#30.0, ACTUAL := FastTune.Y, DELTA := REAL#0.001);
FastTune(SET_REQ := FALSE, SU := FALSE, SD := FALSE, FU := FALSE, FD := FALSE, RST := TRUE, LIMIT_L := REAL#0.0, LIMIT_H := REAL#100.0, RST_val := REAL#7.0, SET_val := REAL#30.0);
ASSERT_NEAR(EXPECTED := REAL#7.0, ACTUAL := FastTune.Y, DELTA := REAL#0.001);

Encoder(CHa := FALSE, CHb := FALSE, RST := TRUE);
ASSERT_EQUAL(EXPECTED := INT#0, ACTUAL := Encoder.cnt);
Encoder(CHa := TRUE, CHb := FALSE, RST := FALSE);
ASSERT_TRUE(IN := Encoder.dir);
ASSERT_EQUAL(EXPECTED := INT#1, ACTUAL := Encoder.cnt);
END_TEST_PROGRAM
