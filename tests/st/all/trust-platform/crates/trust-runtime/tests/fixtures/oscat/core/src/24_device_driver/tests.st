TEST_PROGRAM oscat_device_driver_switching_helpers_behave
VAR
    Driver : DRIVER_1;
    Driver4 : DRIVER_4;
    Driver4C : DRIVER_4C;
    Flow : FLOW_CONTROL;
END_VAR

Driver(SET_REQ := FALSE, IN := FALSE, RST := TRUE, Timeout := T#0s, Toggle_Mode := FALSE);
ASSERT_FALSE(IN := Driver.Q);
Driver(SET_REQ := FALSE, IN := TRUE, RST := FALSE, Timeout := T#0s, Toggle_Mode := FALSE);
ASSERT_TRUE(IN := Driver.Q);
Driver(SET_REQ := FALSE, IN := FALSE, RST := TRUE, Timeout := T#0s, Toggle_Mode := FALSE);
ASSERT_FALSE(IN := Driver.Q);

Driver4(SET_REQ := FALSE, IN0 := TRUE, IN1 := FALSE, IN2 := FALSE, IN3 := FALSE, RST := FALSE, Toggle_Mode := FALSE, Timeout := T#0s);
ASSERT_TRUE(IN := Driver4.Q0);
ASSERT_FALSE(IN := Driver4.Q1);

Driver4C(IN := TRUE, RST := FALSE, Timeout := T#0s);
ASSERT_EQUAL(EXPECTED := INT#1, ACTUAL := Driver4C.SN);
ASSERT_TRUE(IN := Driver4C.Q0);
ASSERT_FALSE(IN := Driver4C.Q1);

Flow(IN := TRUE, REQ := FALSE, ENQ := TRUE, RST := FALSE, T_AUTO := T#0s, T_DELAY := T#0s);
ASSERT_TRUE(IN := Flow.Q);
ASSERT_EQUAL(EXPECTED := BYTE#101, ACTUAL := Flow.STATUS);
END_TEST_PROGRAM

TEST_PROGRAM oscat_device_driver_interlocks_and_manuals_behave
VAR
    Lock2 : INTERLOCK;
    Lock4 : INTERLOCK_4;
    Manual1 : MANUAL_1;
    Manual2 : MANUAL_2;
    Manual4 : MANUAL_4;
END_VAR

Lock2(I1 := TRUE, I2 := FALSE, TL := T#0s);
ASSERT_TRUE(IN := Lock2.Q1);
ASSERT_FALSE(IN := Lock2.Q2);

Lock4(I0 := FALSE, I1 := TRUE, I2 := TRUE, I3 := FALSE, E := TRUE, MODE := INT#1);
ASSERT_EQUAL(EXPECTED := BYTE#4, ACTUAL := Lock4.OUT);
ASSERT_TRUE(IN := Lock4.TP);

ASSERT_TRUE(IN := MANUAL(IN := TRUE, FORCE_ON := FALSE, FORCE_OFF := FALSE));
ASSERT_FALSE(IN := MANUAL(IN := TRUE, FORCE_ON := FALSE, FORCE_OFF := TRUE));

Manual1(IN := FALSE, MAN := TRUE, M_I := TRUE, SET_REQ := FALSE, RST := FALSE);
ASSERT_TRUE(IN := Manual1.Q);
ASSERT_EQUAL(EXPECTED := BYTE#103, ACTUAL := Manual1.STATUS);

Manual2(IN := FALSE, ENA := TRUE, FORCE_ON := TRUE, FORCE_OFF := FALSE, MAN := FALSE);
ASSERT_TRUE(IN := Manual2.Q);
ASSERT_EQUAL(EXPECTED := BYTE#101, ACTUAL := Manual2.STATUS);

Manual4(I0 := FALSE, I1 := FALSE, I2 := FALSE, I3 := FALSE, MAN := TRUE, STP := FALSE, M0 := TRUE, M1 := FALSE, M2 := TRUE, M3 := FALSE);
ASSERT_TRUE(IN := Manual4.Q0);
ASSERT_FALSE(IN := Manual4.Q1);
ASSERT_TRUE(IN := Manual4.Q2);
ASSERT_FALSE(IN := Manual4.Q3);
END_TEST_PROGRAM

