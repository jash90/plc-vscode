TEST_PROGRAM oscat_math_linear_and_polynomial_helpers_behave
VAR
    Coefficients : ARRAY[0..7] OF REAL;
END_VAR

Coefficients[0] := REAL#1.0;
Coefficients[1] := REAL#2.0;
Coefficients[2] := REAL#3.0;
Coefficients[3] := REAL#0.0;
Coefficients[4] := REAL#0.0;
Coefficients[5] := REAL#0.0;
Coefficients[6] := REAL#0.0;
Coefficients[7] := REAL#0.0;

ASSERT_NEAR(EXPECTED := REAL#10.0, ACTUAL := F_LIN(X := REAL#2.0, A := REAL#3.0, B := REAL#4.0), DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#4.0, ACTUAL := F_LIN2(X := REAL#2.0, X1 := REAL#0.0, Y1 := REAL#0.0, X2 := REAL#4.0, Y2 := REAL#8.0), DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#17.0, ACTUAL := F_POLY(X := REAL#2.0, C := Coefficients), DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#18.0, ACTUAL := F_POWER(A := REAL#2.0, X := REAL#3.0, N := REAL#2.0), DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#11.0, ACTUAL := F_QUAD(X := REAL#2.0, A := REAL#1.0, B := REAL#2.0, C := REAL#3.0), DELTA := REAL#0.0001);
END_TEST_PROGRAM

TEST_PROGRAM oscat_math_frmp_b_behaves
ASSERT_EQUAL(EXPECTED := BYTE#35, ACTUAL := FRMP_B(START := BYTE#10, DIR := TRUE, TD := T#100ms, TR := T#1s));
ASSERT_EQUAL(EXPECTED := BYTE#189, ACTUAL := FRMP_B(START := BYTE#240, DIR := FALSE, TD := T#200ms, TR := T#1s));
ASSERT_EQUAL(EXPECTED := BYTE#255, ACTUAL := FRMP_B(START := BYTE#10, DIR := TRUE, TD := T#1s, TR := T#1s));
ASSERT_EQUAL(EXPECTED := BYTE#0, ACTUAL := FRMP_B(START := BYTE#10, DIR := FALSE, TD := T#1s, TR := T#1s));
END_TEST_PROGRAM

TEST_PROGRAM oscat_math_ft_avg_behaves
VAR
    Avg : FT_AVG;
END_VAR

Avg(IN := REAL#4.0, E := TRUE, N := INT#4, RST := TRUE);
ASSERT_NEAR(EXPECTED := REAL#4.0, ACTUAL := Avg.AVG, DELTA := REAL#0.0001);

Avg(IN := REAL#8.0, E := TRUE, N := INT#4, RST := FALSE);
ASSERT_NEAR(EXPECTED := REAL#5.0, ACTUAL := Avg.AVG, DELTA := REAL#0.0001);

Avg(IN := REAL#12.0, E := FALSE, N := INT#4, RST := FALSE);
ASSERT_NEAR(EXPECTED := REAL#5.0, ACTUAL := Avg.AVG, DELTA := REAL#0.0001);

Avg(IN := REAL#10.0, E := TRUE, N := INT#4, RST := TRUE);
ASSERT_NEAR(EXPECTED := REAL#10.0, ACTUAL := Avg.AVG, DELTA := REAL#0.0001);
END_TEST_PROGRAM

TEST_PROGRAM oscat_math_ft_min_max_and_ramp_helpers_behave
VAR
    Stats : FT_MIN_MAX;
    Ramp : FT_RMP;
END_VAR

Stats(IN := REAL#2.0, RST := FALSE);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Stats.MN, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Stats.MX, DELTA := REAL#0.0001);

Stats(IN := REAL#5.0, RST := FALSE);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Stats.MN, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#5.0, ACTUAL := Stats.MX, DELTA := REAL#0.0001);

Stats(IN := REAL#-1.0, RST := FALSE);
ASSERT_NEAR(EXPECTED := REAL#-1.0, ACTUAL := Stats.MN, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#5.0, ACTUAL := Stats.MX, DELTA := REAL#0.0001);

Stats(IN := REAL#7.0, RST := TRUE);
ASSERT_NEAR(EXPECTED := REAL#7.0, ACTUAL := Stats.MN, DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#7.0, ACTUAL := Stats.MX, DELTA := REAL#0.0001);

Ramp(RMP := FALSE, IN := REAL#0.0, KR := REAL#0.0, KF := REAL#0.0);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Ramp.OUT, DELTA := REAL#0.0001);
ASSERT_FALSE(IN := Ramp.BUSY);

Ramp(RMP := TRUE, IN := REAL#10.0, KR := REAL#0.0, KF := REAL#0.0);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Ramp.OUT, DELTA := REAL#0.0001);
ASSERT_TRUE(IN := Ramp.BUSY);
ASSERT_TRUE(IN := Ramp.UD);

Ramp(RMP := TRUE, IN := REAL#-5.0, KR := REAL#0.0, KF := REAL#0.0);
ASSERT_NEAR(EXPECTED := REAL#0.0, ACTUAL := Ramp.OUT, DELTA := REAL#0.0001);
ASSERT_TRUE(IN := Ramp.BUSY);
ASSERT_FALSE(IN := Ramp.UD);

Ramp(RMP := FALSE, IN := REAL#2.0, KR := REAL#0.0, KF := REAL#0.0);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := Ramp.OUT, DELTA := REAL#0.0001);
ASSERT_FALSE(IN := Ramp.BUSY);
END_TEST_PROGRAM

TEST_PROGRAM oscat_math_interpolation_helpers_behave
VAR
    LinearPoints : ARRAY[1..20, 0..1] OF REAL;
    PolyPoints : ARRAY[1..5, 0..1] OF REAL;
END_VAR

LinearPoints[1, 0] := REAL#0.0;
LinearPoints[1, 1] := REAL#0.0;
LinearPoints[2, 0] := REAL#10.0;
LinearPoints[2, 1] := REAL#20.0;
LinearPoints[3, 0] := REAL#20.0;
LinearPoints[3, 1] := REAL#40.0;
ASSERT_NEAR(EXPECTED := REAL#10.0, ACTUAL := LINEAR_INT(X := REAL#5.0, XY := LinearPoints, PTS := INT#3), DELTA := REAL#0.0001);
ASSERT_NEAR(EXPECTED := REAL#30.0, ACTUAL := LINEAR_INT(X := REAL#15.0, XY := LinearPoints, PTS := INT#3), DELTA := REAL#0.0001);

PolyPoints[1, 0] := REAL#0.0;
PolyPoints[1, 1] := REAL#0.0;
PolyPoints[2, 0] := REAL#1.0;
PolyPoints[2, 1] := REAL#1.0;
PolyPoints[3, 0] := REAL#2.0;
PolyPoints[3, 1] := REAL#4.0;
ASSERT_NEAR(EXPECTED := REAL#9.0, ACTUAL := POLYNOM_INT(X := REAL#3.0, XY := PolyPoints, PTS := INT#3), DELTA := REAL#0.001);
END_TEST_PROGRAM
