TEST_PROGRAM oscat_sensors_multi_in_modes_behave
ASSERT_NEAR(
    EXPECTED := REAL#20.0,
    ACTUAL := MULTI_IN(REAL#10.0, REAL#20.0, REAL#30.0, REAL#99.0, REAL#0.0, REAL#100.0, BYTE#0),
    DELTA := REAL#0.001
);
ASSERT_NEAR(
    EXPECTED := REAL#20.0,
    ACTUAL := MULTI_IN(REAL#10.0, REAL#20.0, REAL#30.0, REAL#99.0, REAL#0.0, REAL#100.0, BYTE#7),
    DELTA := REAL#0.001
);
ASSERT_NEAR(
    EXPECTED := REAL#99.0,
    ACTUAL := MULTI_IN(REAL#-5.0, REAL#105.0, REAL#205.0, REAL#99.0, REAL#0.0, REAL#100.0, BYTE#0),
    DELTA := REAL#0.001
);
ASSERT_NEAR(
    EXPECTED := REAL#10.0,
    ACTUAL := MULTI_IN(REAL#10.0, REAL#20.0, REAL#30.0, REAL#99.0, REAL#0.0, REAL#100.0, BYTE#5),
    DELTA := REAL#0.001
);
ASSERT_NEAR(
    EXPECTED := REAL#30.0,
    ACTUAL := MULTI_IN(REAL#10.0, REAL#20.0, REAL#30.0, REAL#99.0, REAL#0.0, REAL#100.0, BYTE#6),
    DELTA := REAL#0.001
);
END_TEST_PROGRAM

TEST_PROGRAM oscat_sensors_resistance_temperature_roundtrips_behave
VAR
    PtResPos : REAL;
    PtResNeg : REAL;
    NiRes : REAL;
    SiRes : REAL;
    NtcRes : REAL;
END_VAR

PtResPos := RES_PT(T := REAL#100.0, R0 := REAL#100.0);
ASSERT_NEAR(EXPECTED := REAL#100.0, ACTUAL := TEMP_PT(Res := PtResPos, R0 := REAL#100.0), DELTA := REAL#0.05);

PtResNeg := RES_PT(T := REAL#-50.0, R0 := REAL#100.0);
ASSERT_NEAR(EXPECTED := REAL#-50.0, ACTUAL := TEMP_PT(Res := PtResNeg, R0 := REAL#100.0), DELTA := REAL#0.05);

NiRes := RES_NI(T := REAL#40.0, R0 := REAL#100.0);
ASSERT_NEAR(EXPECTED := REAL#40.0, ACTUAL := TEMP_NI(Res := NiRes, R0 := REAL#100.0), DELTA := REAL#0.05);

SiRes := RES_SI(T := REAL#50.0, RS := REAL#1000.0, TS := REAL#25.0);
ASSERT_NEAR(EXPECTED := REAL#50.0, ACTUAL := TEMP_SI(Res := SiRes, RS := REAL#1000.0, TS := REAL#25.0), DELTA := REAL#0.1);

NtcRes := RES_NTC(T := REAL#25.0, RN := REAL#10000.0, B := REAL#3435.0);
ASSERT_NEAR(EXPECTED := REAL#25.0, ACTUAL := TEMP_NTC(Res := NtcRes, RN := REAL#10000.0, B := REAL#3435.0), DELTA := REAL#0.05);
END_TEST_PROGRAM

TEST_PROGRAM oscat_sensors_sensor_int_behaves
