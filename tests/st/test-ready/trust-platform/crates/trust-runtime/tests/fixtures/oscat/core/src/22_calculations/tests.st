TEST_PROGRAM oscat_temperature_conversions_behave
ASSERT_TRUE(IN := OSCAT_BASIC_Constants());
ASSERT_NEAR(EXPECTED := REAL#77.0, ACTUAL := C_TO_F(REAL#25.0), DELTA := REAL#0.01);
ASSERT_NEAR(EXPECTED := REAL#25.0, ACTUAL := F_TO_C(REAL#77.0), DELTA := REAL#0.01);
ASSERT_NEAR(EXPECTED := REAL#298.15, ACTUAL := C_TO_K(REAL#25.0), DELTA := REAL#0.01);
ASSERT_NEAR(EXPECTED := REAL#25.0, ACTUAL := K_TO_C(REAL#298.15), DELTA := REAL#0.01);
END_TEST_PROGRAM

TEST_PROGRAM oscat_speed_and_frequency_conversions_behave
VAR
    SpeedMps : REAL;
    SpeedKmh : REAL;
    AngularFrequency : REAL;
    RoundTripFrequency : REAL;
    Period : TIME;
END_VAR

ASSERT_TRUE(IN := OSCAT_BASIC_Constants());
SpeedMps := KMH_TO_MS(REAL#36.0);
SpeedKmh := MS_TO_KMH(SpeedMps);
AngularFrequency := F_TO_OM(REAL#2.0);
RoundTripFrequency := OM_TO_F(AngularFrequency);
Period := F_TO_PT(REAL#2.0);

ASSERT_NEAR(EXPECTED := REAL#10.0, ACTUAL := SpeedMps, DELTA := REAL#0.01);
ASSERT_NEAR(EXPECTED := REAL#36.0, ACTUAL := SpeedKmh, DELTA := REAL#0.01);
ASSERT_NEAR(EXPECTED := MATH.PI2 * REAL#2.0, ACTUAL := AngularFrequency, DELTA := REAL#0.01);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := RoundTripFrequency, DELTA := REAL#0.01);
ASSERT_EQUAL(EXPECTED := INT#5, ACTUAL := MS_TO_BFT(BFT_TO_MS(INT#5)));
ASSERT_EQUAL(EXPECTED := T#500ms, ACTUAL := Period);
ASSERT_NEAR(EXPECTED := REAL#2.0, ACTUAL := PT_TO_F(T#500ms), DELTA := REAL#0.001);
END_TEST_PROGRAM

TEST_PROGRAM oscat_direction_helpers_behave
ASSERT_TRUE(IN := OSCAT_BASIC_Constants());
ASSERT_EQUAL(EXPECTED := 'N', ACTUAL := DEG_TO_DIR(INT#0, INT#1, INT#1));
ASSERT_EQUAL(EXPECTED := 'E', ACTUAL := DEG_TO_DIR(INT#90, INT#1, INT#1));
ASSERT_EQUAL(EXPECTED := 'O', ACTUAL := DEG_TO_DIR(INT#90, INT#1, INT#2));
ASSERT_EQUAL(EXPECTED := INT#90, ACTUAL := DIR_TO_DEG('E', INT#1));
ASSERT_EQUAL(EXPECTED := INT#90, ACTUAL := DIR_TO_DEG('O', INT#2));
ASSERT_EQUAL(EXPECTED := 'E', ACTUAL := LANGUAGE.DIRS[INT#1, INT#4]);
END_TEST_PROGRAM

TEST_PROGRAM oscat_geographic_conversion_behaves
ASSERT_NEAR(
    EXPECTED := REAL#59.5,
    ACTUAL := GEO_TO_DEG(INT#59, INT#30, REAL#0.0),
    DELTA := REAL#0.001
);
END_TEST_PROGRAM

