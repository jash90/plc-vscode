TEST_PROGRAM oscat_control_modules_hysteresis_helpers_behave
VAR
    H1 : HYST;
    H2 : HYST_1;
    H3 : HYST_2;
    H4 : HYST_3;
END_VAR

H1(IN := REAL#12.0, HIGH_LIMIT := REAL#10.0, LOW_LIMIT := REAL#8.0);
ASSERT_TRUE(IN := H1.Q);
ASSERT_FALSE(IN := H1.WIN);

H2(IN := REAL#5.0, high := REAL#4.0, low := REAL#2.0);
ASSERT_TRUE(IN := H2.Q);
ASSERT_FALSE(IN := H2.WIN);

H3(IN := REAL#12.0, VAL := REAL#10.0, HYS := REAL#2.0);
ASSERT_TRUE(IN := H3.Q);
ASSERT_FALSE(IN := H3.WIN);

H4(IN := REAL#4.0, hyst := REAL#2.0, val1 := REAL#6.0, val2 := REAL#8.0);
ASSERT_TRUE(IN := H4.Q1);
ASSERT_FALSE(IN := H4.Q2);
END_TEST_PROGRAM

TEST_PROGRAM oscat_control_modules_hyst_2_retains_state_inside_window
VAR
    H3 : HYST_2;
    QHigh : BOOL := FALSE;
    WinHigh : BOOL := FALSE;
    QWindow : BOOL := FALSE;
    WinWindow : BOOL := FALSE;
    QLow : BOOL := FALSE;
    WinLow : BOOL := FALSE;
END_VAR

H3(IN := REAL#12.0, VAL := REAL#10.0, HYS := REAL#2.0);
QHigh := H3.Q;
WinHigh := H3.WIN;

H3(IN := REAL#9.5, VAL := REAL#10.0, HYS := REAL#2.0);
QWindow := H3.Q;
WinWindow := H3.WIN;

H3(IN := REAL#8.5, VAL := REAL#10.0, HYS := REAL#2.0);
QLow := H3.Q;
WinLow := H3.WIN;

ASSERT_TRUE(IN := QHigh);
ASSERT_FALSE(IN := WinHigh);
ASSERT_TRUE(IN := QWindow);
ASSERT_TRUE(IN := WinWindow);
ASSERT_FALSE(IN := QLow);
ASSERT_FALSE(IN := WinLow);
END_TEST_PROGRAM

