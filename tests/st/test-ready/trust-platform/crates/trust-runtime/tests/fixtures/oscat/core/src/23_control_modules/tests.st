TEST_PROGRAM oscat_control_modules_building_blocks_behave
VAR
    Coil : ACTUATOR_COIL;
    Window : TIMER_1;
    BoilerCtrl : BOILER;
    HeatingCurve : HEAT_TEMP;
    OutsideTemp : TEMP_EXT;
END_VAR

Coil(IN := TRUE);
ASSERT_TRUE(IN := Coil.OUT);
ASSERT_EQUAL(EXPECTED := BYTE#101, ACTUAL := Coil.STATUS);

Window(E := TRUE, DTI := DT#2026-01-04-10:30:00, START := TOD#10:00:00, DURATION := T#1h, DAY := BYTE#127);
ASSERT_TRUE(IN := Window.Q);

BoilerCtrl(T_upper := REAL#45.0, T_lower := REAL#45.0, Pressure := TRUE, enable := TRUE, Req_1 := FALSE, Req_2 := FALSE, Boost := FALSE);
ASSERT_TRUE(IN := BoilerCtrl.Heat);
ASSERT_FALSE(IN := BoilerCtrl.error);
ASSERT_EQUAL(EXPECTED := BYTE#102, ACTUAL := BoilerCtrl.status);

HeatingCurve(T_EXT := REAL#0.0, T_INT := REAL#20.0, OFFSET := REAL#0.0, T_REQ := REAL#0.0);
ASSERT_TRUE(IN := HeatingCurve.HEAT);
ASSERT_NEAR(EXPECTED := REAL#52.4, ACTUAL := HeatingCurve.TY, DELTA := REAL#2.0);

OutsideTemp(t_ext1 := REAL#-15.0, t_ext2 := REAL#-14.0, t_ext3 := REAL#-16.0, t_ext_config := BYTE#0, dt_in := DT#2026-01-15-12:00:00);
ASSERT_TRUE(IN := OutsideTemp.heat);
ASSERT_FALSE(IN := OutsideTemp.cool);
END_TEST_PROGRAM
